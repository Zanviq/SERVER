# 복사해서 .env 로 사용 (.env 는 git 제외)

# 사용자 파일 저장소 루트
#  - 라즈베리파이: /mnt/hdd
#  - 로컬 개발(Windows): ./data
STORAGE_ROOT=/mnt/hdd

# CORS 허용 오리진 (콤마 구분). 개발 중엔 * 허용.
CORS_ORIGINS=*

# Gemini API 키 (3단계 AI 기능에서 사용)
GEMINI_API_KEY=

# 업로드 1건 최대 크기 (바이트). 기본 2GB.
MAX_UPLOAD_BYTES=2147483648

# 4단계: Cloudflare Tunnel 토큰 (대시보드에서 발급)
# docker compose --profile tunnel up -d 로 실행
CF_TUNNEL_TOKEN=
